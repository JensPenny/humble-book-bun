PGHOST=postgres
PGPORT=5432
PGDATABASE=humble_bundles
PGUSER=youruser
PGPASSWORD=yourpassword

GITHUB_USERNAME=yourusername
GITHUB_EMAIL=you@example.com
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXX
GITHUB_REPO_URL=github.com/youruser/yourrepo.git

# Rating source priority (comma-separated list)
# Default order: hardcover,openlibrary,goodreads
# Each source is tried in order until a rating is found
RATING_SOURCE_PRIORITY=hardcover,openlibrary,goodreads

# Hardcover API token (get from hardcover.app account settings > Hardcover API)
# Recommended primary source. No rate limits, generous free tier.
HARDCOVER_API_TOKEN=

# OpenLibrary requires no API key. It is used automatically as a fallback.

# Goodreads cookies (optional, rarely works due to AWS WAF)
# Get from browser DevTools: Network tab > any goodreads.com request > Cookie header
# Paste raw value, do not wrap in quotes
GOODREADS_COOKIE=